{
  "manifest_version": 3,
  "name": "Context Notif Manager",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "idle",
    "storage",
    "alarms",
    "offscreen",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["telemetryContent.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["overlayUI.js"],
      "run_at": "document_idle"
    }
  ]
}
